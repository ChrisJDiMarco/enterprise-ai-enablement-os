# Enterprise AI Enablement OS - server-side provider vault
#
# Keep production secrets on the server. The Admin settings modal can still
# use browser-local keys for workstation testing, but deployment should prefer
# these environment variables.

# Persistence
# Use a NON-SUPERUSER role here so Row-Level Security tenant isolation applies.
DATABASE_URL=
DATABASE_SSL=false
# Max Postgres pool connections per instance (default 10).
DATABASE_POOL_MAX=10
# The maintenance worker reaches cross-tenant tables (workflow_jobs,
# idempotency_records, tenant discovery) that are FORCE-RLS, so the WORKER PROCESS
# must connect as a dedicated PRIVILEGED role with BYPASSRLS. Set this only in the
# worker's environment, never the web app's. Falls back to DATABASE_URL if unset.
WORKER_DATABASE_URL=
DEFAULT_ORGANIZATION_ID=default
# Production blocks file persistence unless this emergency override is explicitly accepted.
ALLOW_FILE_DATABASE_IN_PRODUCTION=false
DB_SCHEMA_VERSION=
DB_MIGRATIONS_APPLIED=false
MANAGED_DATABASE_BACKUPS=false
DATABASE_BACKUP_URL=
DATABASE_BACKUP_SCHEDULE=
DATABASE_RESTORE_DRILL_AT=
PG_BACKUP_BUCKET=
S3_BACKUP_BUCKET=
RESTORE_DRILL_VERIFIED=false

# Auth / SSO
# Set AUTH_REQUIRED=true in production. Configure OIDC for enterprise SSO.
AUTH_SECRET=change-me-with-a-32-byte-random-secret
AUTH_REQUIRED=false
LOCAL_LOGIN_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3002/api/auth/oidc/callback
# Require IdP-asserted MFA. With AUTH_REQUIRE_MFA=true, the OIDC id_token must
# prove multi-factor via an `amr` MFA method or a strong `acr`. Optionally pin an
# exact acr value the IdP must return (e.g. an Okta/Entra step-up policy acr).
AUTH_REQUIRE_MFA=false
OIDC_REQUIRED_ACR=

# Enterprise user lifecycle provisioning
# Configure your IdP/SCIM job to call /api/provisioning/users with
# Authorization: Bearer <token> and x-eaieos-tenant: <organization-id>.
#
# Provisioning tokens are TENANT-BOUND: a token may only provision into the
# tenant(s) it is mapped to. A leaked token can never reach other tenants.
#
# Preferred (multi-tenant) — comma/newline-separated "<org>:<token-or-sha256:hash>":
#   PROVISIONING_TOKENS=acme:tok_live_xxx, globex:sha256:<sha256-hex-of-token>
PROVISIONING_TOKENS=
# Legacy single-tenant token, bound to PROVISIONING_TOKEN_ORG
# (falls back to DEFAULT_ORGANIZATION_ID, then "default").
PROVISIONING_API_TOKEN=
SCIM_BEARER_TOKEN=
PROVISIONING_TOKEN_ORG=
ALLOW_MANUAL_USER_PROVISIONING_IN_PRODUCTION=false

# API security
API_TRUSTED_ORIGINS=http://localhost:3002
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
API_AI_RATE_LIMIT_MAX=90
API_WORKSPACE_RATE_LIMIT_MAX=240
API_WRITE_RATE_LIMIT_MAX=80
API_SENSITIVE_RATE_LIMIT_WINDOW_MS=900000
API_SENSITIVE_RATE_LIMIT_MAX=20
# Required in production (>=16 chars) so per-client rate-limit keys are not
# guessable. Production readiness/preflight FAILS without it unless you set
# ALLOW_UNSALTED_RATE_LIMITS_IN_PRODUCTION=true for a scoped beta.
API_RATE_LIMIT_KEY_SALT=
ALLOW_UNSALTED_RATE_LIMITS_IN_PRODUCTION=false
API_MAX_BODY_BYTES=5000000

# Self-serve onboarding and encrypted tenant-owned provider secrets
SELF_SERVE_SIGNUP_ENABLED=false
CUSTOMER_ONBOARDING_TERMS_URL=
TENANT_SECRET_KEY=change-me-with-a-32-byte-random-secret

# Private-beta escape hatches. Keep false for customer production.
ALLOW_LOCAL_MODEL_RUNTIME_IN_PRODUCTION=false
ALLOW_POLICY_ONLY_CONNECTORS_IN_PRODUCTION=false
ALLOW_LOCAL_WORKFLOW_ENGINE_IN_PRODUCTION=false
ALLOW_MANUAL_CONTEXT_INDEXING_IN_PRODUCTION=false
ALLOW_LOCAL_OBSERVABILITY_IN_PRODUCTION=false

# Model ops guardrails
TENANT_MONTHLY_BUDGET_USD=
MODEL_BUDGET_USD=
MODEL_BUDGET_ENFORCEMENT_ENABLED=false

# Connector / MCP broker
MCP_BROKER_URL=
CONNECTOR_BROKER_URL=
CONNECTOR_BROKER_TOKEN=
CONNECTOR_BROKER_TIMEOUT_MS=30000

# Enterprise connector tenant secrets can be stored through the Admin provider vault
# or supplied as server env vars. Values are never exposed to the browser.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_WEBHOOK_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
SERVICENOW_INSTANCE_URL=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ALLOWLIST=
WORKDAY_TENANT_URL=
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=

# Optional connector activation evidence flags. Set after a customer connector
# has passed a safe read test, a gated write/action test, and evidence capture.
# CONNECTOR_SLACK_READ_TESTED=true
# CONNECTOR_SLACK_ACTION_GATE_TESTED=true
# CONNECTOR_SLACK_EVIDENCE_TESTED=true
# CONNECTOR_SHAREPOINT_READ_TESTED=true
# CONNECTOR_SHAREPOINT_ACTION_GATE_TESTED=true
# CONNECTOR_SHAREPOINT_EVIDENCE_TESTED=true

# Workflow engine
TEMPORAL_ADDRESS=
WORKFLOW_ENGINE_URL=

# Context ingestion
VECTOR_STORE_URL=
CONTEXT_INDEX_JOB_URL=
CONTEXT_SYNC_WORKER_URL=
CONTEXT_SYNC_ENABLED=false

# Evaluation runner
EVAL_RUNNER_URL=
EVAL_SCHEDULE_ENABLED=false
EVAL_SCHEDULE_CRON=
AUDIT_INTEGRITY_ENABLED=true

# Observability and privacy lifecycle
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
LOG_DRAIN_URL=
# Prometheus scrape endpoint /api/metrics. With METRICS_TOKEN set, scrapers send
# Authorization: Bearer <token>; without it, /api/metrics requires an admin session in prod.
METRICS_TOKEN=
# Operational alerting webhook (PagerDuty/Slack/Sentry). Fired on budget-block etc.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TOKEN=
DATA_RETENTION_DAYS=
PRIVACY_EXPORT_ENABLED=false
PRIVACY_REQUEST_WORKFLOW_URL=
DSR_WORKFLOW_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Gemini / Google
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Kimi / Moonshot
KIMI_API_KEY=
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# GLM / Z.AI
GLM_API_KEY=
ZAI_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
