{
  "name": "enterprise-ai-enablement-os",
  "version": "0.1.0",
  "description": "Open-source enterprise AI enablement operating system for governed rollout, proof, adoption, and ROI.",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisJDiMarco/enterprise-ai-enablement-os.git"
  },
  "bugs": {
    "url": "https://github.com/ChrisJDiMarco/enterprise-ai-enablement-os/issues"
  },
  "homepage": "https://github.com/ChrisJDiMarco/enterprise-ai-enablement-os#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:design": "node scripts/check-design-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON \"tests/*.test.ts\"",
    "test:integration": "node --test --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON \"tests/integration/*.test.ts\"",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "smoke:flows": "node scripts/smoke-flows.mjs",
    "smoke:marketing": "node scripts/smoke-marketing.mjs",
    "smoke": "npm run smoke:api && npm run smoke:ui && npm run smoke:flows && npm run smoke:marketing",
    "db:migrate": "node scripts/db-migrate.mjs",
    "worker": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/worker.mjs",
    "setup:production-env": "node scripts/create-production-env.mjs",
    "preflight:launch": "node scripts/preflight-launch.mjs",
    "verify": "npm run typecheck && npm run lint && npm run check:design && npm run typecheck:test && npm test && npm run build && npm run smoke",
    "verify:launch": "npm run verify && npm run preflight:launch"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
